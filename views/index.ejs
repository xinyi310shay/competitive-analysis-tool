<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>竞品分析工具</title>
  <style>
    /* Woodsmoke Neutral Scale (12 stops, cool blue-shifted darks) */
    :root {
      --woodsmoke-25: #FAFAFA;
      --woodsmoke-50: #F5F5F6;
      --woodsmoke-100: #F0F1F1;
      --woodsmoke-200: #ECECED;
      --woodsmoke-300: #CECFD2;
      --woodsmoke-400: #94969C;
      --woodsmoke-500: #85888E;
      --woodsmoke-600: #61646C;
      --woodsmoke-700: #333741;
      --woodsmoke-800: #1F242F;
      --woodsmoke-900: #161B26;
      --woodsmoke-950: #0C111D;

      /* Semantic tokens — Light mode */
      --background: #ffffff;
      --foreground: var(--woodsmoke-950);
      --card: #ffffff;
      --card-foreground: var(--woodsmoke-950);
      --primary: var(--woodsmoke-900);
      --primary-foreground: var(--woodsmoke-50);
      --secondary: var(--woodsmoke-100);
      --secondary-foreground: var(--woodsmoke-900);
      --muted: var(--woodsmoke-100);
      --muted-foreground: var(--woodsmoke-500);
      --accent: var(--woodsmoke-100);
      --accent-foreground: var(--woodsmoke-900);
      --border: var(--woodsmoke-200);
      --input: var(--woodsmoke-300);
      --ring: var(--woodsmoke-400);
      --surface: var(--woodsmoke-50);
      --surface-foreground: var(--woodsmoke-900);
      --success: #10b981;
      --warning: #f59e0b;
      --error: #ef4444;
      
      /* Radius system */
      --radius: 0.625rem;
      --radius-sm: calc(var(--radius) * 0.6);
      --radius-md: calc(var(--radius) * 0.8);
      --radius-lg: var(--radius);
      --radius-xl: calc(var(--radius) * 1.4);
      
      /* Typography */
      --font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
    }

    * {
      box-sizing: border-box;
    }

    body {
      font-family: var(--font-sans);
      line-height: 1.6;
      color: var(--foreground);
      background: var(--background);
      margin: 0;
      padding: 0;
      min-height: 100vh;
    }

    .container-wrapper {
      width: 100%;
      padding: 0.5rem;
      max-width: calc(1400px + 2rem);
      margin: 0 auto;
    }

    .container {
      max-width: 1400px;
      padding: 1rem;
      margin: 0 auto;
    }

    @media (min-width: 1024px) {
      .container {
        padding: 2rem;
      }
    }

    h1 {
      font-size: 1.875rem;
      font-weight: 600;
      line-height: 1.2;
      letter-spacing: -0.025em;
      text-align: center;
      margin-bottom: 2rem;
      color: var(--card-foreground);
    }

    @media (min-width: 1024px) {
      h1 {
        font-size: 2.25rem;
      }
    }

    .card {
      background: var(--card);
      border-radius: var(--radius-lg);
      border: 1px solid var(--border);
      box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
      padding: 1.5rem;
    }

    @media (min-width: 768px) {
      .card {
        padding: 2rem;
      }
    }

    .form-group {
      margin-bottom: 1.5rem;
    }

    .form-group label {
      display: block;
      margin-bottom: 0.5rem;
      font-weight: 500;
      font-size: 0.875rem;
      color: var(--card-foreground);
    }

    .form-group textarea {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid var(--input);
      border-radius: var(--radius-md);
      font-family: inherit;
      font-size: 0.875rem;
      color: var(--card-foreground);
      background: var(--background);
      resize: vertical;
      min-height: 120px;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .form-group textarea:focus {
      outline: none;
      border-color: var(--ring);
      box-shadow: 0 0 0 3px rgba(148, 150, 156, 0.1);
    }

    .form-group select {
      width: 100%;
      padding: 0.75rem;
      border: 1px solid var(--input);
      border-radius: var(--radius-md);
      font-family: inherit;
      font-size: 0.875rem;
      color: var(--card-foreground);
      background: var(--background);
      cursor: pointer;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .form-group select:focus {
      outline: none;
      border-color: var(--ring);
      box-shadow: 0 0 0 3px rgba(148, 150, 156, 0.1);
    }

    .checkbox-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 0.75rem;
    }

    .checkbox-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem;
      background: var(--surface);
      border-radius: var(--radius-md);
      border: 1px solid var(--border);
      cursor: pointer;
      transition: all 0.2s;
    }

    .checkbox-item:hover {
      background: var(--muted);
    }

    .checkbox-item input[type="checkbox"] {
      width: 1rem;
      height: 1rem;
      cursor: pointer;
      accent-color: var(--primary);
    }

    .checkbox-item label {
      margin: 0;
      cursor: pointer;
      font-size: 0.875rem;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      font-family: inherit;
      font-size: 0.875rem;
      font-weight: 500;
      border: none;
      border-radius: var(--radius-md);
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
    }

    .btn-primary {
      background: var(--primary);
      color: var(--primary-foreground);
    }

    .btn-primary:hover {
      background: var(--woodsmoke-800);
      transform: translateY(-1px);
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }

    .btn-primary:active {
      transform: translateY(0);
    }

    .btn-primary:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }

    .full-width {
      width: 100%;
    }

    .loading-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(255, 255, 255, 0.95);
      display: none;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      z-index: 1000;
    }

    .loading-overlay.active {
      display: flex;
    }

    .spinner {
      width: 50px;
      height: 50px;
      border: 4px solid var(--muted);
      border-top-color: var(--primary);
      border-radius: 50%;
      animation: spin 1s linear infinite;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    .loading-text {
      margin-top: 1rem;
      font-size: 1rem;
      color: var(--muted-foreground);
    }

    .hint {
      margin-top: 0.25rem;
      font-size: 0.75rem;
      color: var(--muted-foreground);
    }

    .section-title {
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 1rem;
      color: var(--card-foreground);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .section-title::before {
      content: '';
      width: 4px;
      height: 1.25rem;
      background: var(--primary);
      border-radius: 2px;
    }
  </style>
</head>
<body>
  <div class="container-wrapper">
    <div class="container">
      <h1>竞品分析工具</h1>
      
      <div class="card">
        <form id="analyzeForm">
          <div class="form-group">
            <div class="section-title">竞品网址</div>
            <textarea 
              id="urls" 
              name="urls" 
              placeholder="请输入要分析的网页链接，每行一个&#10;例如：&#10;https://example.com&#10;https://competitor.com"
              required
            ></textarea>
            <p class="hint">每行输入一个网址，可以输入多个竞品进行对比分析</p>
          </div>
          
          <div class="form-group">
            <div class="section-title">产品类型</div>
            <select id="productType" name="productType" required>
              <option value="">请选择产品类型</option>
              <option value="ecommerce">电商平台</option>
              <option value="saas">SaaS 产品</option>
              <option value="social">社交产品</option>
              <option value="content">内容平台</option>
              <option value="tool">工具类产品</option>
              <option value="mobile">移动应用</option>
              <option value="other">其他类型</option>
            </select>
          </div>
          
          <div class="form-group">
            <div class="section-title">分析维度</div>
            <div class="checkbox-grid">
              <div class="checkbox-item">
                <input type="checkbox" id="visual" name="dimensions" value="visual" checked>
                <label for="visual">视觉风格</label>
              </div>
              <div class="checkbox-item">
                <input type="checkbox" id="information" name="dimensions" value="information" checked>
                <label for="information">信息架构</label>
              </div>
              <div class="checkbox-item">
                <input type="checkbox" id="interaction" name="dimensions" value="interaction" checked>
                <label for="interaction">交互设计</label>
              </div>
              <div class="checkbox-item">
                <input type="checkbox" id="usability" name="dimensions" value="usability" checked>
                <label for="usability">可用性</label>
              </div>
              <div class="checkbox-item">
                <input type="checkbox" id="brand" name="dimensions" value="brand">
                <label for="brand">品牌表达</label>
              </div>
              <div class="checkbox-item">
                <input type="checkbox" id="content" name="dimensions" value="content">
                <label for="content">内容策略</label>
              </div>
            </div>
          </div>
          
          <button type="submit" class="btn btn-primary full-width">
            开始分析
          </button>
        </form>
      </div>
    </div>
  </div>

  <div class="loading-overlay" id="loadingOverlay">
    <div class="spinner"></div>
    <p class="loading-text">正在分析竞品，请稍候...</p>
  </div>

  <script>
    document.getElementById('analyzeForm').addEventListener('submit', function(e) {
      e.preventDefault();
      
      const formData = new FormData(this);
      const data = {
        urls: formData.get('urls'),
        productType: formData.get('productType'),
        dimensions: formData.getAll('dimensions')
      };
      
      document.getElementById('loadingOverlay').classList.add('active');
      
      fetch('/analyze', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
      })
      .then(response => response.text())
      .then(html => {
        document.open();
        document.write(html);
        document.close();
      })
      .catch(error => {
        console.error('Error:', error);
        alert('分析过程中出现错误，请重试');
        document.getElementById('loadingOverlay').classList.remove('active');
      });
    });
  </script>
</body>
</html>